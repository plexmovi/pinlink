# PinLink - Environment Variables Template
# Copia este archivo como .env y configura tus valores

# Puerto del servidor
PORT=3000

# PIN de autenticación (6 dígitos)
AUTH_PIN=198823

# URL base de tu aplicación (cambia esto en producción)
BASE_URL=http://localhost:3000

# Connection string de Neon Database
# Obtén esto desde el dashboard de Neon
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Secret para las cookies de sesión
SESSION_SECRET=tu-session-secret-aqui-muy-largo-y-seguro
